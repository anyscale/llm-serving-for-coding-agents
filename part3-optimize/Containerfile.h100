# Containerfile — production image for the optimized Qwen3.6-27B-FP8 service (H100 / Azure AKS).
#
# Adapted from part3-optimize/Containerfile: the runai-model-streamer packages are dropped
# because the fast-loading path streams from AWS S3, which this Azure cluster cannot reach.
# Re-add `runai-model-streamer` (+ an Azure-reachable weights mirror) if you opt back in.
#
# PIN the base for production. For a fully immutable build, replace the tag with its digest:
#   FROM anyscale/ray-llm@sha256:<digest>
FROM anyscale/ray-llm:2.56.0-py312-cu130

# vLLM 0.23.0 supports Claude Code's current /v1/messages schema; the base image ships 0.22.0.
RUN pip install --no-cache-dir "vllm==0.23.0" "scipy>=1.13"

# PATCH: vLLM 0.23.0 (and 0.25.1) forwards Anthropic "tool_reference" content items (sent by
# Claude Code's deferred MCP tool loading) RAW into the chat template; the Qwen3.6 template
# only accepts text/image/video items and 500s with "Unexpected item type in content."
# This rewrites them to plain-text markers in the tool result (the full tool definitions
# arrive via the request's tools array anyway). Base64-embedded because Anyscale image
# builds have no COPY context. The build FAILS if the patch anchor is missing (version drift).
RUN echo "" | base64 -d | python3

