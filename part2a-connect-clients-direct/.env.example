# Copy this to `.env` in this folder and fill in the three REQUIRED values below.
# These settings are SHARED by all three agents (Claude Code, Codex, Cursor) and the smoke
# test — one place for your connection details. `.env` is gitignored; never commit real tokens.
#
#   cp .env.example .env  &&  $EDITOR .env
#
# Part 2a connects agents DIRECTLY to the service's native endpoints (no proxy).
# It requires the service to have DIRECT STREAMING enabled — Part 1 / Part 3 do.

# ── REQUIRED (used by all three agents) ─────────────────────────────────────
# From the Anyscale console: Services → your service → Query.
ANYSCALE_BASE_URL="https://YOUR-ANYSCALE-SERVICE-HOST.s.anyscaleuserdata.com/v1"  # MUST end in /v1, no trailing slash
ANYSCALE_API_KEY="paste-your-anyscale-bearer-token-here"                         # raw token, no "Bearer " prefix
ANYSCALE_MODEL="qwen3.6-27b"                                                      # must match the served model id (curl $BASE/models)

# ── Optional (shared) ───────────────────────────────────────────────────────
API_TIMEOUT_MS="1200000"   # 20 min — lets clients wait out a cold start (ALB still caps a single request at 300s)

# Codex-specific tuning (provider id, context window, max output tokens) is NOT set here — it lives in
# codex_config.toml and as defaults in run-codex-direct.sh, so this file stays common to all three
# agents. You only need to add those vars here if you want to override a default.
