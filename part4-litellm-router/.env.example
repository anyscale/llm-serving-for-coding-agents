# Copy this to `.env` in this folder and fill in the two REQUIRED values.
# Shared by run-claude-router.sh and client.py. `.env` is gitignored; never
# commit real keys.
#
#   cp .env.example .env  &&  $EDITOR .env

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Gateway URL from `anyscale service status --name litellm-router-gateway`
# (or the deploy output / console). Service ROOT — no /v1, no trailing slash.
GATEWAY_BASE_URL="https://YOUR-GATEWAY-HOST.s.anyscaleuserdata.com"
# The LITELLM_MASTER_KEY you set in gateway/service.yaml (or a per-user virtual key).
LITELLM_MASTER_KEY="sk-paste-the-gateway-master-key"

# ── Optional ────────────────────────────────────────────────────────────────
# Default model for run-claude-router.sh. One of:
#   smart-router (default) | anyscale-qwen3.6-27b | claude-opus-4-8
# ROUTER_MODEL="smart-router"
# API_TIMEOUT_MS="1200000"   # 20 min client-side; the gateway caps upstream calls at 600s
